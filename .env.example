# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=vending
POSTGRES_USER=vending
POSTGRES_PASSWORD=vending123
DATABASE_URL=postgresql://vending:vending123@postgres:5432/vending

# ============================================
# FLASK SERVER CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=1

# ============================================
# MQTT BROKER CONFIGURATION
# ============================================
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=vending_server

# ============================================
# IMAGE UPLOAD CONFIGURATION
# ============================================
MAX_IMAGE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,png,webp
STATIC_IMAGE_PATH=/app/static/images

# ============================================
# DASHBOARD CONFIGURATION
# ============================================
# Khi chạy trong Docker Compose, server service là "server"
# Khi chạy local, dùng localhost
DASHBOARD_SERVER_URL=http://server:5000
API_URL=http://server:5000

# Dashboard admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=DEBUG
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================
# DEBUG MODE (Set to True in production)
# ============================================
DEBUG=True

# ============================================
# TIMEZONE
# ============================================
TZ=Asia/Ho_Chi_Minh

# ============================================
# CLOUDFLARE TUNNEL (Optional)
# ============================================
# CLOUDFLARE_TUNNEL_TOKEN=your-token-here